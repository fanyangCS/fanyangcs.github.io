      aria-current="page"
    {% endif %}
    >About</a
  >
  <a
    href="{{ '/blog/' | relative_url }}"
    {% if include.current == 'blog' %}
      aria-current="page"
    {% endif %}
    >Blog</a
  >
  <a
    href="{{ '/news/' | relative_url }}"
    {% if include.current == 'news' %}
      aria-current="page"
    {% endif %}
    >News</a
  >
  <a
    href="{{ '/publications/' | relative_url }}"
    {% if include.current == 'publications' %}
