<div class="victoria-secondary-page victoria-news-page">
  {% include victoria_nav.liquid current="news" %}

  <h1 class="victoria-secondary-title">News</h1>

  {% assign news = site.news | reverse %}
  {% assign page_news = news | slice: page.news_offset, 5 %}

  {% if page_news != blank %}
    <div class="victoria-resource-list victoria-news-list">
      {% for item in page_news %}
        <article class="victoria-resource-panel victoria-news-item">
          <h2>
            {% if item.inline %}
              <span>{{ item.title }}</span>
            {% else %}
              <a class="news-title" href="{{ item.url | relative_url }}">{{ item.title }}</a>
            {% endif %}
          </h2>
          <p class="victoria-news-meta">
            <time datetime="{{ item.date | date: '%Y-%m-%d' }}">{{ item.date | date: '%B %d, %Y' }}</time>
          </p>
        </article>
      {% endfor %}
    </div>
  {% else %}
    <p>No news so far...</p>
  {% endif %}

  <div class="victoria-pagination">
    <nav aria-label="News page navigation">
      <ul class="pagination pagination-lg justify-content-center">
        <li class="page-item {% if page.news_page == 1 %}disabled{% endif %}">
          {% if page.news_page == 1 %}
            <a class="page-link" href="" tabindex="-1" aria-disabled="true">Newer</a>
          {% elsif page.news_page == 2 %}
            <a class="page-link" href="{{ '/news/' | relative_url }}">Newer</a>
          {% else %}
            <a class="page-link" href="{{ '/news/page/2/' | relative_url }}">Newer</a>
          {% endif %}
        </li>
        {% for number in (1..3) %}
          <li class="page-item {% if page.news_page == number %}active{% endif %}">
            {% if number == 1 %}
              {% assign number_path = '/news/' %}
            {% else %}
              {% assign number_path = '/news/page/' | append: number | append: '/' %}
            {% endif %}
            <a class="page-link" href="{{ number_path | relative_url }}">{{ number }}</a>
          </li>
        {% endfor %}
        <li class="page-item {% if page.news_page == 3 %}disabled{% endif %}">
          {% if page.news_page == 3 %}
            <a class="page-link" href="" tabindex="-1" aria-disabled="true">Older</a>
          {% else %}
            {% assign next_page = page.news_page | plus: 1 %}
            {% assign next_path = '/news/page/' | append: next_page | append: '/' %}
            <a class="page-link" href="{{ next_path | relative_url }}">Older</a>
          {% endif %}
        </li>
      </ul>
    </nav>
  </div>

  <p class="victoria-back-link"><a href="{{ '/' | relative_url }}">&larr; Back</a></p>
</div>
