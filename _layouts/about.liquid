---
layout: default
---
<div class="academic-home">
  <aside class="academic-sidebar" aria-label="Homepage sidebar">
    <nav class="academic-nav" aria-label="Homepage sections">
      <div class="academic-nav-title">Navigation</div>
      <a href="#about">About</a>
      {% if page.news and site.announcements.enabled %}
        <a href="#news">News</a>
      {% endif %}
      {% if page.selected_papers %}
        <a href="#publications">Publications</a>
      {% endif %}
    </nav>

    <section class="academic-identity" aria-label="Profile">
      {% if page.profile and page.profile.image %}
        {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
        <img class="academic-avatar" src="{{ profile_image_path | relative_url }}" alt="{{ site.first_name }} {{ site.last_name }}">
      {% endif %}
      <h1 class="academic-name">
        {% if site.title == 'blank' %}
          {{ site.first_name -}}
          {%- if site.middle_name %} {{ site.middle_name }}{% endif %}
          {{ site.last_name }}
        {% else %}
          {{ site.title }}
        {% endif %}
      </h1>
      <p class="academic-subtitle">{{ page.subtitle }}</p>
      {% if page.profile.more_info %}
        <div class="academic-more-info">{{ page.profile.more_info }}</div>
      {% endif %}
      {% if page.social %}
        <div class="academic-social" aria-label="Social links">{% include social.liquid %}</div>
      {% endif %}
    </section>
  </aside>

  <main class="academic-main">
    <section id="about" class="academic-section about-me-section">
      <h2>About Me</h2>
      <div class="academic-copy">{{ content }}</div>
    </section>

    {% if page.news and site.announcements.enabled %}
      <section id="news" class="academic-section academic-news-section">
        <h2>
          <a href="{{ '/news/' | relative_url }}">News</a>
        </h2>
        {% include news.liquid limit=true %}
      </section>
    {% endif %}

    {% if page.selected_papers %}
      <section id="publications" class="academic-section academic-publications-section">
        <h2>
          <a href="{{ '/publications/' | relative_url }}">Selected Publications</a>
        </h2>
        <p class="publication-note">
          A concise selection of recent work. See the full <a href="{{ '/publications/' | relative_url }}">publications page</a>
          {%- if site.scholar_userid %}
            or <a href="https://scholar.google.com/citations?user={{ site.scholar_userid }}">Google Scholar</a>
          {%- endif %}
          for more.
        </p>
        {% include selected_papers.liquid %}
      </section>
    {% endif %}
  </main>
</div>
